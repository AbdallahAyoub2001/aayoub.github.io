---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Abdallah Ayoub | Home">
	<section
		class="min-h-[80vh] flex flex-col items-center justify-center px-6 text-center"
	>
		<div class="mb-8">
			<img
				src="/profile.jpg"
				alt="Abdallah Ayoub"
				class="w-48 h-48 rounded-full border-4 border-blue-500/30 object-cover shadow-2xl"
			/>
		</div>

		<div class="max-w-2xl">
			<h1 class="text-5xl font-extrabold tracking-tight text-white mb-4">
				Hello, I'm <span class="text-blue-500">Abdallah!</span>
			</h1>

			<p class="text-xl text-gray-400 leading-relaxed mb-6">
				Software Engineer & AI Researcher. I specialize in building
				<span class="text-white font-medium"
					>high-precision RAG systems</span
				>
				for medical genetics and evaluating the <span
					class="text-white font-medium"
					>fairness of synthetic data</span
				>
				generated by Large Language Models.
			</p>

			<div class="flex gap-4 justify-center">
				<a
					href="/projects"
					class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg font-medium transition-all"
				>
					View My Work
				</a>
				<a
					href="/resume"
					class="border border-gray-700 hover:border-gray-500 text-white px-6 py-2 rounded-lg font-medium transition-all"
				>
					My Resume
				</a>
			</div>
		</div>
	</section>
</Layout>
