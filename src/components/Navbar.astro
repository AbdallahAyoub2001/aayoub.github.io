---
// src/components/Navbar.astro
---

<header
    class="flex justify-between items-center py-6 px-8 bg-[#0a0a0a] text-white border-b border-gray-800"
>
    <nav class="flex gap-8 text-sm font-medium tracking-wide">
        <a href="/" class="hover:text-blue-400 transition-colors">Home</a>
        <a href="/resume" class="hover:text-blue-400 transition-colors"
            >Resume</a
        >
        <a href="/projects" class="hover:text-blue-400 transition-colors"
            >Projects</a
        >
    </nav>

    <div class="flex gap-5 items-center">
        <a
            href="mailto:abdullah.ayyoub2001@gmail.com"
            class="hover:text-blue-400 transition-colors"
            aria-label="Email"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
                    d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
            >
        </a>

        <a
            href="https://github.com/AbdallahAyoub2001"
            target="_blank"
            class="hover:text-blue-400 transition-colors"
            aria-label="GitHub"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                    d="M15 22v-4a4.8 4.8 0 0 0-1-3.02c3.19-.34 6.52-1.58 6.52-7.02 0-1.53-.54-2.86-1.43-3.92.14-.35.62-1.86-.14-3.86 0 0-1.2-.38-3.9 1.45a13.4 13.4 0 0 0-7 0c-2.7-1.83-3.9-1.45-3.9-1.45-.76 2-.28 3.51-.14 3.86-.89 1.06-1.43 2.39-1.43 3.92 0 5.44 3.33 6.68 6.52 7.02-.44.4-.83 1.1-.97 2.13-.86.39-3.03 1.05-4.37-1.25 0 0-.8-1.45-2.3-1.56 0 0-1.5-.02-.1.95 0 0 1.05.6 1.7 2.8 0 0 .9 2.8 5.1 1.98v3"
                ></path></svg
            >
        </a>

        <a
            href="https://www.linkedin.com/in/abdallah-ayoub-5aa3351a5"
            target="_blank"
            class="hover:text-blue-400 transition-colors"
            aria-label="LinkedIn"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                    d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                ></path><rect width="4" height="12" x="2" y="9"></rect><circle
                    cx="4"
                    cy="4"
                    r="2"></circle></svg
            >
        </a>
    </div>
</header>
